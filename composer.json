{
  "name": "laravelcm/laravelcm",
  "type": "project",
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel",
    "community",
    "Cameroon"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "ext-fileinfo": "*",
    "ext-json": "*",
    "ext-libxml": "*",
    "ext-simplexml": "*",
    "archtechx/laravel-seo": "^0.10.4",
    "awcodes/filament-badgeable-column": "^3.1",
    "codeat3/blade-phosphor-icons": "^2.4",
    "cyrildewit/eloquent-viewable": "^7.1.0",
    "diglactic/laravel-breadcrumbs": "^10.1",
    "ezyang/htmlpurifier": "^4.19",
    "filament/filament": "^5.5.1",
    "filament/spatie-laravel-media-library-plugin": "^5.5.1",
    "gehrisandro/tailwind-merge-laravel": "^1.4",
    "graham-campbell/markdown": "^16.1",
    "guzzlehttp/guzzle": "^7.10.0",
    "internachi/modular": "^3.0.2",
    "jenssegers/agent": "^2.6.4",
    "lara-zeus/spatie-translatable": "^2.0",
    "laravel-notification-channels/telegram": "^7.0",
    "laravel-notification-channels/twitter": "dev-master as 9.1.0",
    "laravel/ai": "^0.3.2",
    "laravel/framework": "^13.5",
    "laravel/nightwatch": "^1.26.1",
    "laravel/octane": "^2.17.1",
    "laravel/reverb": "^1.10.0",
    "laravel/scout": "^11.1",
    "laravel/socialite": "^5.26.1",
    "laravel/tinker": "^3.0.2",
    "laravelcm/gamify": "^1.1",
    "laravelcm/laravel-subscriptions": "^1.8.0",
    "laravelcm/livewire-slide-overs": "^2.0.3",
    "laravelcm/sentinel": ">=1",
    "league/flysystem-aws-s3-v3": "^3.32.0",
    "lettr/lettr-laravel": "^1.4",
    "livewire/flux": "^2.13.2",
    "livewire/flux-pro": "^2.13.2",
    "mckenziearts/filament-untitledui-icons": "^1.2",
    "mckenziearts/laravel-notify": "^3.2.0",
    "mckenziearts/livewire-markdown-editor": "^1.3.0",
    "notchpay/notchpay-php": "^2.0",
    "predis/predis": "^3.4.2",
    "ramsey/uuid": "^4.9.2",
    "shopperlabs/pureline-theme": "^1.2",
    "spatie/laravel-data": "^4.22.0",
    "spatie/laravel-feed": "^4.5.0",
    "spatie/laravel-mail-preview": "^6.2.2",
    "spatie/laravel-permission": "^6.25.0",
    "spatie/laravel-sitemap": "^7.4.0",
    "stevebauman/location": "^7.6.3",
    "torchlight/torchlight-laravel": "^0.6.2",
    "typesense/typesense-php": "^6.0",
    "yarri/link-finder": "^2.8.2",
    "ysfkaya/filament-phone-input": "^4.1.3"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^4.2.6",
    "driftingly/rector-laravel": "^2.3.0",
    "fakerphp/faker": "^1.24.1",
    "larastan/larastan": "^3.9.6",
    "laravel/boost": "^2.4.4",
    "laravel/breeze": "^2.4.1",
    "laravel/pail": "^1.2.6",
    "laravel/pint": "^1.29.0",
    "mischasigtermans/laravel-altitude": "^0.2.0",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.3",
    "pestphp/pest": "^4.6.1",
    "pestphp/pest-plugin-laravel": "^4.1",
    "pestphp/pest-plugin-livewire": "^4.1",
    "pestphp/pest-plugin-type-coverage": "^4.0.4",
    "spatie/test-time": "^1.3.3"
  },
  "autoload": {
    "files": [
      "app/helpers.php"
    ],
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "dev:install": [
      "composer install",
      "docker compose up -d",
      "npm install --no-update-notifier",
      "npm run build"
    ],
    "dev:uninstall": "docker compose down --rmi all --volumes --remove-orphans",
    "dev:run": [
      "Composer\\Config::disableProcessTimeout",
      "docker compose up -d",
      "npx concurrently -c \"#505b92,#d32d21\" \"composer install\" \"npm install --no-update-notifier\" --names=composer,npm",
      "npx concurrently -c \"#fb7185,#fdba74,#22d3ee\" \"php artisan pail --timeout=0\" \"npm run dev\" \"php artisan reverb:start --host=0.0.0.0 --port=8080\" --names=logs,vite,reverb"
    ],
    "dev:stop": "docker compose down",
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi",
      "@php artisan filament:upgrade"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
      "@php artisan clear",
      "@update:requirements",
      "@php artisan boost:update --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "update:requirements": [
      "composer bump",
      "npx npm-check-updates -u"
    ],
    "lint": [
      "rector",
      "pint --parallel",
      "npm run lint"
    ],
    "test:lint": [
      "pint --parallel --test",
      "rector --dry-run",
      "npm run test:lint"
    ],
    "refactor": "./vendor/bin/rector",
    "test:refactor": "./vendor/bin/rector --dry-run",
    "test:unit": "pest --parallel --coverage --min=30.0",
    "test:types": "phpstan analyse --memory-limit=-1",
    "test:type-coverage": "pest --type-coverage --min=90 --memory-limit=-1",
    "test": [
      "@test:type-coverage",
      "@test:types",
      "@test:unit"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": false
    }
  },
  "repositories": [
    {
      "name": "flux-pro",
      "type": "composer",
      "url": "https://composer.fluxui.dev"
    },
    {
      "type": "path",
      "url": "app-modules/*",
      "options": {
        "symlink": true
      }
    },
    {
      "type": "composer",
      "url": "https://pureline.composer.sh"
    }
  ],
  "prefer-stable": true,
  "minimum-stability": "stable"
}
